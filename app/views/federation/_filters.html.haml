- if filters.present?
  .panel-group{ id: "filters", role: "tablist", "aria-multiselectable": "true" }
    %h5.underline-light.mb-2.pb-2.mt-4
      .row
        .col-7.text-uppercase
          = _("Filters")

    -# haml-lint:disable InstanceVariables
    - filters.each do |key, elements|
      - label = defined?(@facets_labels) && @facets_labels.present? ? (@facets_labels[key] || key.humanize) : key.humanize
      :ruby
        active_eids = Array(params[key])
        if key == "categories"
          active_eids += Array(params[:supercategories]) + Array(params[:subcategories])
        elsif key == "scientific_domains"
          active_eids += Array(params[:scientific_subdomains])
        end
      = render "federation/filters/multiselect", name: key, label: label, elements: elements, active: active_eids
    -# haml-lint:enable InstanceVariables

    .row.mt-3
      .col-12
        .d-flex.justify-content-between
          = button_tag "Clear filters",
            type: "button",
            class: "btn btn-outline-secondary",
            data: { action: "click->federation-filters#clearFilters" }

          %button.btn.btn-primary{ type: "submit" }
            Apply filters
