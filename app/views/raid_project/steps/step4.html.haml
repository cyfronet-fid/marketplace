- content_for :title, _("Create new RAID Project")
- breadcrumb :project_new
.container
  #form-container
    .mb-5.pb-2.border-header
      %h1.mr-auto.my-auto= _("Create new RAID Project")
  = turbo_frame_tag "raid-form" do
    = simple_form_for @raid_project, remote: local_assigns[:show_as_modal],
          html: { role: "form", id: "modal-form", "data-controller" => "raid-access" },
          url: wizard_path, method: :put do |f|
      .new-form-style{ data: {"raid-form-target": "section", section: "access" } }
        = f.input :form_step, as: :hidden, input_html: { value:"step4" }

        %h4 Access
        .offer-section-wrapper.bottom-margin
          = f.error :access_base, class: "invalid-feedback d-block"
          = f.fields_for :raid_access do |access_f|
            = access_f.hidden_field :id
            = access_f.input :access_type, as: :select,
                    collection: Raid::RaidAccess.access_types.map { |k, v| [ k.capitalize, v ] },
                    input_html: {"data-raid-access-target": "accessType",
                      "data-action": "raid-access#setEmbargoed",
                      data: { choice: true },  multiple: false }
            %div
              %h5
                = _("Statement")
              = access_f.input :statement_text, label: "Text"
              = access_f.input :statement_lang, label: "Language",
                collection: Raid::Language.all,
                label_method: :english_name,
                value_method: :alpha3,
                include_hidden: true,
                input_html: { data: { choice: true },  multiple: false }
              = access_f.input :embargo_expiry,  as: :date, html5: true,
                  wrapper_html: {"data-raid-access-target" => "embargoExpiry"},
                  input_html: {"data-raid-access-target" => "embargoExpiryInput"}

        %hr.bottom-hr.mt-5.mb-4
          .row
            .col-12
              = f.button :submit, "Next", class: "btn btn-primary pl-5 pr-5"
